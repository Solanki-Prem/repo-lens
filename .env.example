OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Where Chroma stores its persistent collections
CHROMA_DIR=.chroma

# Where cloned repos are cached. Cleared on demand.
REPO_CACHE_DIR=.repo_cache

# Skip files larger than this (bytes). Default 200 KB.
MAX_FILE_BYTES=204800
